    <raw-text role="processing">
      <sentence n="1">
        <kanji>今勅久</kanji>
        <transcription>ima nori tamapa ku</transcription>
      </sentence>
      <sentence n="2">
        <kanji>掛畏岐</kanji>
        <transcription>kake maku mo kasikwo ki</transcription>
      </sentence>
      <sentence n="3">
        <kanji>近淡海乃大津宮仁天下所知行之</kanji>
        <transcription>apumi no opo tu no miya ni ame no sita sira si myesi si</transcription>
      </sentence>
      <sentence n="4">
        <kanji>天皇我御世尔奉侍末之之</kanji>
        <transcription>sumyera ga mi yo ni tukape maturi masi si</transcription>
      </sentence>
      <sentence n="5">
        <kanji>藤原大臣復後乃藤原大臣尔賜天在留</kanji>
        <transcription>pudi para no opo mapye tu kimi mata noti no pudi para no opo mapye tu kimi ni tamapi te a ru</transcription>
      </sentence>
      <sentence n="6">
        <kanji>志乃比己止乃書尔勅天在久子孫乃浄久明伎</kanji>
        <transcription>sinwobi koto no pumi ni nori tamapi te ara ku umi no kwo no kiywo ku aka ki</transcription>
      </sentence>
      <sentence n="7">
        <kanji>心乎以天</kanji>
        <transcription>kokoro wo moti te</transcription>
      </sentence>
      <sentence n="8">
        <kanji>朝庭尔奉侍牟乎波必治賜牟</kanji>
        <transcription>mikadwo ni tukape matura mu woba kanarazu wosame tamapa mu</transcription>
      </sentence>
      <sentence n="9">
        <kanji>其継方絶不賜止</kanji>
        <transcription>so no tugi pa tati tamapazi to</transcription>
      </sentence>
      <sentence n="10">
        <kanji>勅天在</kanji>
        <transcription>nori tamapi te aru</transcription>
      </sentence>
      <sentence n="11">
        <kanji>我故尔</kanji>
        <transcription>ga yuwe ni</transcription>
      </sentence>
      <sentence n="12">
        <kanji>今藤原永手朝臣尔右大臣之官授賜止勅</kanji>
        <transcription>ima pudi para no nagate no asomi ni migi no opo mapye tu kimi no tukasa wo saduke tamapu to noritamapu</transcription>
      </sentence>
      <sentence n="13">
        <kanji>天皇御命遠諸聞食止宣</kanji>
        <transcription>sumyera ga opo mikoto wo moro moro kiki tamapeyo to noritamapu</transcription>
      </sentence>
    </raw-text>
