      </sentence>
      <sentence n="12">
        <kanji>進留</kanji>
        <transcription>tate matu ru</transcription>
      </sentence>
      <sentence n="13">
        <kanji>神財波御弓御大刀御鏡鈴衣笠御馬乎引竝弖</kanji>
        <transcription>kamudakara pa mi torasi mi pakasi mi kagami suzu kinu gasa mi ma wo piki narabe te</transcription>
      </sentence>
      <sentence n="14">
        <kanji>御衣波明多</kanji>
