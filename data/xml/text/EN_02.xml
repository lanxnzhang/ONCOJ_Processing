    <raw-text role="processing">
      <sentence n="1">
        <kanji>如此仕奉爾依弖</kanji>
        <transcription>kaku tukape maturu ni yori te</transcription>
      </sentence>
      <sentence n="2">
        <kanji>今母去</kanji>
        <transcription>ima mo yuku</transcription>
      </sentence>
      <sentence n="3">
        <kanji>前毛天皇我朝庭乎平久安久</kanji>
        <transcription>saki mo sumyera ga mikadwo wo tapirake ku yasurake ku</transcription>
      </sentence>
      <sentence n="4">
        <kanji>足御世乃</kanji>
        <transcription>tara si mi yo no ikasi</transcription>
      </sentence>
      <sentence n="5">
        <kanji>茂御世爾齋奉利</kanji>
        <transcription>mi yo ni ipapi matu ri</transcription>
      </sentence>
      <sentence n="6">
        <kanji>常石爾</kanji>
        <transcription>tok ipa ni</transcription>
      </sentence>
      <sentence n="7">
        <kanji>堅石爾福閇奉利</kanji>
        <transcription>kak ipa ni sakipa pe matu ri</transcription>
      </sentence>
      <sentence n="8">
        <kanji>預而</kanji>
        <transcription>adukari te</transcription>
      </sentence>
      <sentence n="9">
        <kanji>仕奉留</kanji>
        <transcription>tukape matu ru</transcription>
      </sentence>
      <sentence n="10">
        <kanji>處〻家〻王等卿等乎毛平久</kanji>
        <transcription>tokoro dokoro ipye ipye no opo kimi tati mapyetugimi tati wo mo tapirake ku</transcription>
      </sentence>
      <sentence n="11">
        <kanji>天皇我朝庭爾伊加志</kanji>
        <transcription>sumyera ga mikadwo ni ikasi</transcription>
      </sentence>
      <sentence n="12">
        <kanji>夜久波叡乃如久仕奉利佐加叡志米賜止</kanji>
        <transcription>yakupaye no goto ku tukape matu ri sakaye sime tamape to</transcription>
      </sentence>
      <sentence n="13">
        <kanji>稱辭竟奉良久止白</kanji>
        <transcription>tatapegoto wope matu raku to mawosu</transcription>
      </sentence>
    </raw-text>
