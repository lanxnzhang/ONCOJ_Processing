      <sentence n="1">
        <kanji>掛母畏支</kanji>
        <transcription>kake maku mo kasikwo ki</transcription>
      </sentence>
      <sentence n="2">
        <kanji>天皇御世御世仕奉而</kanji>
        <transcription>sumyera ga miyo miyo tukape maturite</transcription>
      </sentence>
      <sentence n="3">
        <kanji>今母又朕卿止為而</kanji>
        <transcription>ima mo mata wa ga mapyetu kimi to site</transcription>
      </sentence>
      <sentence n="4">
        <kanji>以明浄心而</kanji>
        <transcription>aka ki kiyo ki kokoro mo motite</transcription>
      </sentence>
      <sentence n="5">
        <kanji>朕呼助奉仕奉</kanji>
        <transcription>ware wo tasuke maturi tukape maturu</transcription>
      </sentence>
      <sentence n="6">
        <kanji>事乃重支労支</kanji>
        <transcription>koto no ikasi ki itapasi ki</transcription>
      </sentence>
      <sentence n="7">
        <kanji>事呼所念坐</kanji>
        <transcription>koto wo omoposi masu</transcription>
      </sentence>
      <sentence n="8">
        <kanji>御意坐尓依而多利麻比氐</kanji>
        <transcription>mi kokoro imasu ni yorite tarimapite</transcription>
      </sentence>
      <sentence n="9">
        <kanji>夜々弥賜閇婆</kanji>
        <transcription>ya ya mi tama peba</transcription>
      </sentence>
      <sentence n="10">
        <kanji>忌忍</kanji>
        <transcription>imi sinuburu</transcription>
      </sentence>
      <sentence n="11">
        <kanji>事尓似</kanji>
        <transcription>koto ni niru</transcription>
      </sentence>
      <sentence n="12">
        <kanji>事呼志奈母常労弥重弥</kanji>
        <transcription>koto wo si namo tune itopasi mi ikasi mi</transcription>
      </sentence>
      <sentence n="13">
        <kanji>所念坐久止宣</kanji>
        <transcription>omoposi masa ku to noritamapu</transcription>
      </sentence>
    </raw-text>
