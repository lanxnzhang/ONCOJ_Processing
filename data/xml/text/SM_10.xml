    <raw-text role="processing">
      <sentence n="1">
        <kanji>現神</kanji>
        <transcription>aki tu mi kamwi to</transcription>
      </sentence>
      <sentence n="2">
        <kanji>御大八洲</kanji>
        <transcription>opo ya sima sira si myesu</transcription>
      </sentence>
      <sentence n="3">
        <kanji>我子天皇乃掛母畏伎</kanji>
        <transcription>wa ga kwo sumyera mikoto no kake maku mo kasikwo ki</transcription>
      </sentence>
      <sentence n="4">
        <kanji>天皇朝廷乃始賜比造賜弊留</kanji>
        <transcription>sumyera ga mikadwo no pazime tama pi tukuri tama p yeru</transcription>
      </sentence>
      <sentence n="5">
        <kanji>宝国宝等之弖</kanji>
        <transcription>takara wo kuni no takara to site</transcription>
      </sentence>
      <sentence n="6">
        <kanji>此王乎令供奉賜波</kanji>
        <transcription>ko no opokimi wo tukape matura sime tamape ba</transcription>
      </sentence>
      <sentence n="7">
        <kanji>天下尓立賜比行賜部流</kanji>
        <transcription>ame no sita ni tate tama pi okonapi tama p yeru</transcription>
      </sentence>
      <sentence n="8">
        <kanji>法波可絶伎</kanji>
        <transcription>nori pa tayu be ki</transcription>
      </sentence>
      <sentence n="9">
        <kanji>事波無久有家利止</kanji>
        <transcription>koto pa na ku ari kyeri to</transcription>
      </sentence>
      <sentence n="10">
        <kanji>見聞喜侍止</kanji>
        <transcription>mi kiki yorokobwi paberi to</transcription>
      </sentence>
      <sentence n="11">
        <kanji>奏賜等詔</kanji>
        <transcription>mawosi tamapye to noritamapu</transcription>
      </sentence>
      <sentence n="12">
        <kanji>大命乎奏</kanji>
        <transcription>opo mikoto wo mawosu</transcription>
      </sentence>
    </raw-text>
