        <kanji>今詔久事卒然尔有依天</kanji>
        <transcription>ima nori tamapa ku koto nipaka ni aru ni yori te</transcription>
      </sentence>
      <sentence n="2">
        <kanji>諸臣等議天</kanji>
        <transcription>omi tati pakari te</transcription>
      </sentence>
      <sentence n="3">
        <kanji>白壁王波諸王乃中尔</kanji>
        <transcription>sira kabe no opo kimi pa opo kimi tati no naka ni</transcription>
      </sentence>
      <sentence n="4">
        <kanji>年歯毛長奈利</kanji>
        <transcription>yopapi mo ko no kami nari</transcription>
      </sentence>
      <sentence n="5">
        <kanji>又先帝乃功毛在</kanji>
        <transcription>mata saki no mikadwo no mi isawo mo aru</transcription>
      </sentence>
      <sentence n="6">
        <kanji>故仁</kanji>
        <transcription>yuwe ni</transcription>
      </sentence>
      <sentence n="7">
        <kanji>太子止定天奏波</kanji>
        <transcription>pi tugi no mi kwo to sadame te mawose ba</transcription>
      </sentence>
      <sentence n="8">
        <kanji>奏流</kanji>
        <transcription>mawos e ru</transcription>
      </sentence>
      <sentence n="9">
